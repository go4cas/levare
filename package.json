{
  "name": "levare",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build": "./scripts/build.sh",
    "validate": "bun run src/cli.ts validate",
    "docs:generate": "bun run scripts/generate-cheatsheets.ts",
    "deps:check": "bun -e \"const d=Object.keys(require('./package.json').dependencies||{});const bad=d.filter(x=>x!=='@anthropic-ai/claude-agent-sdk');if(bad.length){console.error('forbidden deps: '+bad);process.exit(1)}console.log('deps ok')\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
